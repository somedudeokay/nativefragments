{
  "name": "@nativefragments/core",
  "version": "0.5.0",
  "description": "Zero dependency, zero build framework core for agents building AI-friendly web applications.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./cloudflare": {
      "types": "./types/cloudflare.d.ts",
      "default": "./src/cloudflare/index.js"
    },
    "./server": {
      "types": "./types/server.d.ts",
      "default": "./src/server/index.js"
    },
    "./client/router.js": {
      "types": "./types/client-router.d.ts",
      "default": "./public/nativefragments/router.js"
    },
    "./client/component.js": {
      "types": "./types/client-component.d.ts",
      "default": "./public/nativefragments/component.js"
    },
    "./client/worker.js": {
      "types": "./types/client-worker.d.ts",
      "default": "./public/nativefragments/worker.js"
    }
  },
  "typesVersions": {
    "*": {
      "cloudflare": [
        "./types/cloudflare.d.ts"
      ],
      "server": [
        "./types/server.d.ts"
      ],
      "client/router.js": [
        "./types/client-router.d.ts"
      ],
      "client/component.js": [
        "./types/client-component.d.ts"
      ],
      "client/worker.js": [
        "./types/client-worker.d.ts"
      ],
      "*": [
        "./types/index.d.ts"
      ]
    }
  },
  "files": [
    "src",
    "public/nativefragments",
    "types",
    "docs",
    "skills",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somedudeokay/nativefragments.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/somedudeokay/nativefragments/issues"
  },
  "homepage": "https://nativefragments.org",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "find src public/nativefragments -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run check && changeset publish"
  },
  "keywords": [
    "web-components",
    "cloudflare-workers",
    "zero-build",
    "fragments",
    "ai-agents",
    "ai-friendly-apps"
  ],
  "license": "MIT",
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0"
  }
}
